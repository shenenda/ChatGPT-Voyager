{
  "manifest_version": 3,
  "name": "ChatGPT Voyager",
  "version": "0.2.0",
  "description": "Adds conversation anchors, manual quote-to-ask, and send-time scroll locking to ChatGPT.",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
